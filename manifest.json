{
  "manifest_version": 3,
  "name": "Local Phishing URL Detector",
  "version": "1.0",
  "description": "Uses an ONNX model to analyze if the current URL is a phishing attempt.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "*.wasm",
        "*.mjs",
        "warning.js",
        "warning.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}